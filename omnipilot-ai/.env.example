# Port the OmniPilot AI server runs on
PORT=5000

# OPTIONAL: If you provide an Anthropic API key, agents will use Claude
# for smarter natural-language reasoning. If left blank, agents fall back
# to fast, fully-offline rule-based logic (no external calls, no key needed).
ANTHROPIC_API_KEY=

# Comma-separated list of origins allowed to call the API (CORS allowlist)
ALLOWED_ORIGINS=http://localhost:5000

# Max requests per IP per minute (simple in-memory rate limiter)
RATE_LIMIT_PER_MINUTE=60
